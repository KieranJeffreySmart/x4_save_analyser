<UserControl
    x:Class="X4SaveAnalyser.UnpackGameData.Desktop.Views.UniverseExtractorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel Margin="8">

        <!-- Action buttons -->
        <StackPanel
            DockPanel.Dock="Bottom"
            HorizontalAlignment="Right"
            Margin="0,8,0,0"
            Orientation="Horizontal">
            <Button
                Margin="0,0,8,0"
                Command="{Binding CancelCommand}"
                Content="Cancel" />
            <Button
                Command="{Binding ExtractCommand}"
                Content="Extract" />
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Source save file -->
            <Label Grid.Row="0" Content="Save file:" FontWeight="SemiBold" />
            <DockPanel Grid.Row="1" Margin="0,2,0,8">
                <Button
                    DockPanel.Dock="Right"
                    Margin="6,0,0,0"
                    IsEnabled="{Binding IsNotBusy}"
                    Click="BrowseSaveFile_Click"
                    Content="Select file…" />
                <TextBlock
                    VerticalAlignment="Center"
                    Foreground="Gray"
                    TextWrapping="Wrap"
                    Text="{Binding SourceFile, Mode=OneWay}" />
            </DockPanel>

            <!-- Output: auto-derived, read-only -->
            <Label Grid.Row="2" Content="Output file (auto: {output root}\saves\{yyyy-MM-dd-HH-mm}\{name}\universe.xml):" FontWeight="SemiBold" />
            <TextBlock
                Grid.Row="3"
                Margin="0,2,0,8"
                Foreground="Gray"
                TextWrapping="Wrap"
                Text="{Binding DestFile, Mode=OneWay}" />

            <!-- Log -->
            <Label Grid.Row="4" Content="Output log:" FontWeight="SemiBold" />
            <TextBox
                x:Name="LogBox"
                Grid.Row="5"
                FontFamily="Consolas"
                FontSize="11"
                HorizontalScrollBarVisibility="Auto"
                IsReadOnly="True"
                Text="{Binding Log, Mode=OneWay}"
                VerticalScrollBarVisibility="Auto" />
        </Grid>
    </DockPanel>
</UserControl>
