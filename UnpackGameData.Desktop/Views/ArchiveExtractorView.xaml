<UserControl
    x:Class="X4SaveAnalyser.UnpackGameData.Desktop.Views.ArchiveExtractorView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <DockPanel Margin="8">

        <!-- Action buttons -->
        <StackPanel
            DockPanel.Dock="Bottom"
            HorizontalAlignment="Right"
            Margin="0,8,0,0"
            Orientation="Horizontal">
            <Button
                Margin="0,0,8,0"
                Command="{Binding CancelCommand}"
                Content="Cancel" />
            <Button
                Command="{Binding ExtractCommand}"
                Content="Extract" />
        </StackPanel>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Source: from game folder setting -->
            <Label Grid.Row="0" Content="Game folder (set in Settings):" FontWeight="SemiBold" />
            <TextBlock
                Grid.Row="1"
                Margin="0,2,0,8"
                Foreground="Gray"
                TextWrapping="Wrap"
                Text="{Binding SourceDir, Mode=OneWay}" />

            <!-- Output: auto-derived, read-only -->
            <Label Grid.Row="2" Content="Output folder (auto: {output root}\game\{version}):" FontWeight="SemiBold" />
            <TextBlock
                Grid.Row="3"
                Margin="0,2,0,8"
                Foreground="Gray"
                TextWrapping="Wrap"
                Text="{Binding DestDir, Mode=OneWay}" />

            <!-- Advanced options + log -->
            <Expander
                Grid.Row="4"
                Margin="0,0,0,8"
                IsExpanded="True"
                Header="Advanced options">
                <Grid Margin="0,8,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Label Grid.Row="0" Content="File filter (regex):" FontWeight="SemiBold" />
                    <TextBox
                        Grid.Row="1"
                        Margin="0,2,0,8"
                        IsEnabled="{Binding IsNotBusy}"
                        Text="{Binding Filter, UpdateSourceTrigger=PropertyChanged}" />

                    <DockPanel Grid.Row="2">
                        <Label DockPanel.Dock="Top" Content="Output log:" FontWeight="SemiBold" />
                        <TextBox
                            x:Name="LogBox"
                            FontFamily="Consolas"
                            FontSize="11"
                            HorizontalScrollBarVisibility="Auto"
                            IsReadOnly="True"
                            Text="{Binding Log, Mode=OneWay}"
                            VerticalScrollBarVisibility="Auto" />
                    </DockPanel>
                </Grid>
            </Expander>
        </Grid>
    </DockPanel>
</UserControl>
