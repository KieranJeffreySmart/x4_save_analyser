<Window
    x:Class="X4SaveAnalyser.UnpackGameData.Desktop.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:views="clr-namespace:X4SaveAnalyser.UnpackGameData.Desktop.Views"
    Title="X4 Save Analyser"
    Width="700"
    Height="560"
    MinWidth="560"
    MinHeight="440"
    WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Padding" Value="10,4" />
            <Setter Property="MinWidth" Value="80" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="4,2" />
        </Style>
        <Style TargetType="Label">
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="12">

        <!-- Status bar -->
        <TextBlock
            DockPanel.Dock="Bottom"
            Margin="0,8,0,0"
            VerticalAlignment="Center"
            Foreground="Gray"
            Text="{Binding StatusMessage}" />

        <!-- Tab control -->
        <TabControl>

            <TabItem Header="Unpack Archives">
                <views:ArchiveExtractorView DataContext="{Binding Archives}" />
            </TabItem>

            <TabItem Header="Extract Universe">
                <views:UniverseExtractorView DataContext="{Binding Universe}" />
            </TabItem>

            <TabItem Header="Settings">
                <views:SettingsView DataContext="{Binding Settings}" />
            </TabItem>

        </TabControl>
    </DockPanel>
</Window>
